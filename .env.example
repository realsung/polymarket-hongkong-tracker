TELEGRAM_BOT_TOKEN=xxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
TELEGRAM_CHAT_ID=000000000

POLL_INTERVAL_SECONDS=10
TEMP_CHANGE_THRESHOLD=0.0
NOTIFY_DAILY_SUMMARY_HKT=21:00

