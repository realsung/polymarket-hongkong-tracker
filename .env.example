TELEGRAM_BOT_TOKEN=xxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
TELEGRAM_CHAT_ID=000000000

POLL_INTERVAL_SECONDS=10
TEMP_CHANGE_THRESHOLD=0.0
NOTIFY_DAILY_SUMMARY_HKT=21:00

# Polymarket buckets (Gamma API) — both highest and lowest events are shown
POLYMARKET_ENABLED=true
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# Leave blank to auto-derive slugs from HKT date
POLYMARKET_EVENT_SLUG_HIGH=
POLYMARKET_EVENT_SLUG_LOW=

DB_PATH=/data/hko.db
LOG_LEVEL=INFO
